# Copy to .env.local and fill in from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your deployed origin (no trailing slash) — powers metadata, Open Graph/Twitter
# image URLs, and the sitemap/robots.txt. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=https://your-deployment-url.vercel.app

# Server-only. Used for self-serve account deletion. NEVER prefix with NEXT_PUBLIC_
# or commit this value. Leave blank to disable Delete account until you're ready.
SUPABASE_SERVICE_ROLE_KEY=
